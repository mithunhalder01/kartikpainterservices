# MongoDB Atlas connection string (create a free cluster at https://www.mongodb.com/atlas)
MONGODB_URI=

# Comma-separated list of origins allowed to call the API with credentials
CORS_ORIGINS=http://localhost:5173

# JWT secrets — generate strong random values, e.g. `openssl rand -hex 64`
JWT_SECRET=
JWT_REFRESH_SECRET=

# Single admin account — used only by the one-time seed script (server/scripts/seedAdmin.js)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# Cloudinary (create a free account at https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Local dev only — port for the standalone Express server (server/local.js)
PORT=5050
